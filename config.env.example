VWA_DATA_DIR=/var/lib/video-work-api
VWA_MODEL_DIR=/var/lib/video-work-api/models/Fun-CosyVoice3-0.5B-2512
VWA_TRANSLATION_MODEL_DIR=/var/lib/video-work-api/models/madlad400-3b-mt
VWA_COSYVOICE_ROOT=/usr/lib/video-work-api/vendor/CosyVoice
VWA_FUNCLIP_ROOT=/usr/lib/video-work-api/vendor/FunClip
VWA_SETUP_TOKEN_FILE=/var/lib/video-work-api/setup-token
VWA_MCP_TOKEN_FILE=/var/lib/video-work-api/mcp-token
VWA_HOST=0.0.0.0
VWA_PORT=7860
VWA_VIDEO_INPUT_DIR=/var/lib/video-work-api/videos
VWA_REFERENCE_INPUT_DIR=/var/lib/video-work-api/references
VWA_VIDEO_PROJECTS_DIR=/var/lib/video-work-api/video-projects
# Existing server-side HMAC-SHA256 key file. It is never auto-generated or
# exposed through REST/MCP; missing means receipt signing is unavailable.
VWA_RECEIPT_KEY_FILE=/etc/xry/render-receipt.hmac.key
# Legacy XRY rows are read/recovered fail-closed only. Direct submission is disabled.
VWA_XRY_TASK_ROOT=/srv/2.预处理/批量剪辑
VWA_XRY_SOURCE_ROOT=/srv/1.素材/批量剪辑
VWA_XRY_RENDERER=/srv/2.预处理/tools-723/render_variants.py
# Must be the real interpreter path, not a symlink (use: readlink -f /usr/bin/python3).
VWA_XRY_PYTHON=/usr/bin/python3.14
VWA_RENDER_TIMEOUT=21600
# Immutable VPE bundle renderer. The service hashes and opens this exact file.
VWA_VIDEO_PROJECT_RENDERER=/usr/lib/video-work-api/scripts/video_project_render.py
VWA_VIDEO_PROJECT_PYTHON=/usr/bin/python3.14
VWA_VIDEO_PROJECT_RENDER_TIMEOUT=7200
# Optional compatibility override. Normally vwactl creates a persistent token file automatically.
# VWA_MCP_TOKEN=
# Optional HTTPS for browser microphone access over LAN; configure both or neither.
# VWA_SSL_CERTFILE=/etc/video-work-api/tls/cert.pem
# VWA_SSL_KEYFILE=/etc/video-work-api/tls/key.pem
# VWA_SUBTITLE_TIMEOUT=1800
# VWA_TRANSLATION_TIMEOUT=600
