VWA_DATA_DIR=/var/lib/video-work-api
VWA_MODEL_DIR=/var/lib/video-work-api/models/Fun-CosyVoice3-0.5B-2512
VWA_COSYVOICE_ROOT=/usr/lib/video-work-api/vendor/CosyVoice
VWA_FUNCLIP_ROOT=/usr/lib/video-work-api/vendor/FunClip
VWA_SETUP_TOKEN_FILE=/var/lib/video-work-api/setup-token
VWA_HOST=0.0.0.0
VWA_PORT=7860
VWA_VIDEO_INPUT_DIR=/var/lib/video-work-api/videos
VWA_REFERENCE_INPUT_DIR=/var/lib/video-work-api/references
# Bearer token for POST /mcp (AI agents). Generate a long random secret.
# VWA_MCP_TOKEN=
# Optional HTTPS for browser microphone access over LAN; configure both or neither.
# VWA_SSL_CERTFILE=/etc/video-work-api/tls/cert.pem
# VWA_SSL_KEYFILE=/etc/video-work-api/tls/key.pem
# VWA_SUBTITLE_TIMEOUT=1800
